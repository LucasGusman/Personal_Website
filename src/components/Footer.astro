---
const year = new Date().getFullYear();
---

<footer class="w-full relative z-10 border-t border-[var(--border-color)] bg-[var(--white-overlay)] mt-24 backdrop-blur-sm transition-colors duration-500">
  <div class="max-w-6xl mx-auto px-6 py-12 flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-[var(--accent-red)] animate-pulse shadow-[0_0_8px_var(--orb-red)] transition-colors duration-500"></span>
      <span class="text-sm font-mono text-[var(--text-primary)]/50 tracking-wide transition-colors duration-500">System Online // {year}</span>
    </div>
    
    <div class="flex items-center gap-6 text-sm font-medium">
      <a href="https://github.com/LucasGusman" target="_blank" rel="noopener noreferrer" class="text-[var(--text-primary)]/60 hover:text-[var(--text-primary)] transition-colors duration-500">GitHub</a>
      <a href="https://www.linkedin.com/in/lucasgusman/" target="_blank" rel="noopener noreferrer" class="text-[var(--text-primary)]/60 hover:text-[var(--text-primary)] transition-colors duration-500">LinkedIn</a>
    </div>
  </div>
</footer>
