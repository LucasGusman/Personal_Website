---
const currentPath = Astro.url.pathname;

const links = [
  { 
    name: 'Home', 
    href: '/',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />`
  },
  { 
    name: 'Galaxy', 
    href: '/galaxy',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>`
  },
  { 
    name: 'Projects', 
    href: '/projects',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />`
  },
  { 
    name: 'Timeline', 
    href: '/timeline',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />`
  },
  { 
    name: 'About', 
    href: '/about',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" />`
  },
  { 
    name: 'Resume', 
    href: '/resume',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><polyline points="10 9 9 9 8 9" />`
  },
];
---

<nav class="fixed bottom-0 left-0 w-full h-16 md:w-20 md:h-screen md:top-0 z-50 bg-[var(--bg-primary)] md:bg-transparent border-t md:border-t-0 md:border-r border-[var(--border-color)] flex md:flex-col items-center justify-between md:justify-start py-0 md:py-8 px-6 md:px-0 transition-colors duration-500">
  
  <!-- Logo -->
  <a href="/" class="hidden md:flex flex-col items-center gap-2 mb-8 group" title="Return to Core">
    <div class="w-8 h-8 rounded-full bg-[var(--accent-red)] flex items-center justify-center transition-transform duration-500 group-hover:rotate-180 group-hover:scale-110 shadow-sm">
      <div class="w-2.5 h-2.5 bg-white rounded-full"></div>
    </div>
  </a>

  <!-- Theme Switches -->
  <div class="hidden md:flex flex-col items-center gap-6 mb-8 w-full border-b border-[var(--border-color)] pb-8">

    <button class="theme-toggle relative p-2 text-[var(--text-primary)]/40 hover:text-[var(--accent-teal)] transition-all duration-300 group flex items-center justify-center" data-anim="power-down" title="Theme: Power Down">
      <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110 group-hover:-translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      <span class="absolute top-full mt-1 left-1/2 opacity-0 -translate-x-1/2 -translate-y-2 group-hover:-translate-x-1/2 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300 whitespace-nowrap text-[9px] font-mono tracking-widest uppercase text-[var(--text-primary)]/70 hidden md:block pointer-events-none">Power</span>
    </button>
    <button class="theme-toggle relative p-2 text-[var(--text-primary)]/40 hover:text-[var(--accent-teal)] transition-all duration-300 group flex items-center justify-center" data-anim="singularity" title="Theme: Singularity">
      <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110 group-hover:-translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4"></path></svg>
      <span class="absolute top-full mt-1 left-1/2 opacity-0 -translate-x-1/2 -translate-y-2 group-hover:-translate-x-1/2 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300 whitespace-nowrap text-[9px] font-mono tracking-widest uppercase text-[var(--text-primary)]/70 hidden md:block pointer-events-none">Singular</span>
    </button>
  </div>
  
  <!-- Navigation Links -->
  <div class="flex md:flex-col items-center justify-between md:justify-center w-full md:w-auto gap-1 md:gap-8 md:flex-grow">
    {links.map(link => {
      const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
      return (
        <a 
          href={link.href} 
          class:list={[
            "relative p-2 transition-all duration-300 group flex items-center justify-center",
            isActive 
              ? "text-[var(--accent-red)]" 
              : "text-[var(--text-primary)]/40 hover:text-[var(--accent-red)]"
          ]}
        >
          <!-- Icon -->
          <svg 
            xmlns="http://www.w3.org/2000/svg" 
            viewBox="0 0 24 24" 
            fill="none" 
            stroke="currentColor" 
            stroke-width="1.5" 
            class:list={[
              "w-5 h-5 transition-transform duration-300 relative z-10",
              isActive ? "scale-110" : "group-hover:scale-110 group-hover:-translate-y-1"
            ]}
            set:html={link.icon}
          />
          
          <!-- Hover Label (Desktop Only) -->
          <span class="absolute top-full mt-1 left-1/2 opacity-0 -translate-x-1/2 -translate-y-2 group-hover:-translate-x-1/2 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300 whitespace-nowrap text-[11px] font-mono tracking-widest uppercase text-[var(--text-primary)]/70 hidden md:block pointer-events-none">
            {link.name}
          </span>
        </a>
      );
    })}
  </div>
  
  <!-- Settings/Contact Icon -->
  <a href="mailto:hello@example.com" class="hidden md:flex p-2 relative text-[var(--text-primary)]/40 hover:text-[var(--accent-red)] transition-all duration-300 group items-center justify-center">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 group-hover:rotate-12 transition-transform relative z-10">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
    </svg>
    <span class="absolute top-full mt-1 left-1/2 opacity-0 -translate-x-1/2 -translate-y-2 group-hover:-translate-x-1/2 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300 whitespace-nowrap text-[11px] font-mono tracking-widest uppercase text-[var(--text-primary)]/70 pointer-events-none">
      CONTACT
    </span>
  </a>
</nav>

<script>
  // Ensure the DOM is fully loaded and Astro transitions are handled
  document.addEventListener('astro:page-load', () => {
    
    const applyTheme = (isDark) => {
      if (isDark) {
        document.documentElement.classList.add('theme-space');
      } else {
        document.documentElement.classList.remove('theme-space');
      }
    };

    // Initial theme check
    const isDark = localStorage.getItem('theme') === 'dark';
    applyTheme(isDark);

    const toggleButtons = document.querySelectorAll('.theme-toggle');
    
    toggleButtons.forEach(button => {
      button.addEventListener('click', (e) => {
        const animType = button.getAttribute('data-anim');
        const currentlyDark = document.documentElement.classList.contains('theme-space');
        const willBeDark = !currentlyDark;

        if (animType === 'hyperdrive') {
          // Canvas Hyperdrive Animation
          let canvas = document.querySelector('.hyperdrive-canvas');
          if (!canvas) {
            canvas = document.createElement('canvas');
            canvas.className = 'hyperdrive-canvas';
            canvas.style.position = 'fixed';
            canvas.style.inset = '0';
            canvas.style.zIndex = '9999';
            canvas.style.pointerEvents = 'none';
            canvas.style.backgroundColor = '#060913'; 
            canvas.style.opacity = '0';
            canvas.style.transition = 'opacity 0.3s ease-in-out';
            document.body.appendChild(canvas);
          }
          
          const ctx = canvas.getContext('2d');
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
          
          const rootStyles = getComputedStyle(document.documentElement);
          const teal = rootStyles.getPropertyValue('--accent-teal').trim() || '#38bdf8';
          const red = rootStyles.getPropertyValue('--accent-red').trim() || '#ff5c6d';

          const stars = [];
          const numStars = 600;
          const centerX = canvas.width / 2;
          const centerY = canvas.height / 2;
          
          for (let i = 0; i < numStars; i++) {
            stars.push({
              x: (Math.random() - 0.5) * canvas.width * 2,
              y: (Math.random() - 0.5) * canvas.height * 2,
              z: Math.random() * 2000,
              pz: Math.random() * 2000
            });
          }
          
          let speed = 0;
          let isFadingOut = false;
          let startTime = Date.now();
          let swapped = false;
          
          requestAnimationFrame(() => {
             canvas.style.opacity = '1';
          });
          
          const draw = () => {
            const elapsed = Date.now() - startTime;
            
            if (elapsed < 1500) {
              speed += 0.5;
            }
            
            ctx.fillStyle = 'rgba(6, 9, 19, 0.4)'; 
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            stars.forEach(star => {
              star.pz = star.z;
              star.z -= speed;
              
              if (star.z < 1) {
                star.x = (Math.random() - 0.5) * canvas.width * 2;
                star.y = (Math.random() - 0.5) * canvas.height * 2;
                star.z = 2000;
                star.pz = 2000;
              }
              
              const sx = centerX + (star.x / star.z) * canvas.width;
              const sy = centerY + (star.y / star.z) * canvas.height;
              const px = centerX + (star.x / star.pz) * canvas.width;
              const py = centerY + (star.y / star.pz) * canvas.height;
              
              const alpha = Math.max(0, 1 - (star.z / 2000));
              ctx.beginPath();
              
              const rand = Math.random();
              if (rand > 0.85) {
                  ctx.strokeStyle = teal;
                  ctx.shadowBlur = 10;
                  ctx.shadowColor = teal;
              } else if (rand > 0.70) {
                  ctx.strokeStyle = red;
                  ctx.shadowBlur = 10;
                  ctx.shadowColor = red;
              } else {
                  ctx.strokeStyle = `rgba(255, 255, 255, ${alpha})`;
                  ctx.shadowBlur = 0;
              }
              
              ctx.lineWidth = Math.max(0.5, (1 - (star.z / 2000)) * 4);
              ctx.moveTo(px, py);
              ctx.lineTo(sx, sy);
              ctx.stroke();
            });
            
            if (elapsed > 1200 && !swapped) {
               swapped = true;
               applyTheme(willBeDark);
               localStorage.setItem('theme', willBeDark ? 'dark' : 'light');
            }
            
            if (elapsed > 2000 && !isFadingOut) {
               isFadingOut = true;
               canvas.style.opacity = '0';
               canvas.style.transition = 'opacity 1s ease-in-out';
            }
            
            if (elapsed < 3200) {
              requestAnimationFrame(draw);
            } else {
              if (canvas) canvas.remove();
            }
          };
          
          draw();
        } 
        else if (animType === 'power-down') {
          // Power Down Animation
          document.body.classList.add('anim-power-down');
          
          setTimeout(() => {
            applyTheme(willBeDark);
            localStorage.setItem('theme', willBeDark ? 'dark' : 'light');
          }, 400); // Change theme in the middle of flicker

          setTimeout(() => {
            document.body.classList.remove('anim-power-down');
          }, 800);
        }
        else if (animType === 'singularity') {
          // Expanding Singularity
          const rect = button.getBoundingClientRect();
          const x = e.clientX;
          const y = e.clientY;
          
          let overlay = document.querySelector('.singularity-overlay');
          if (!overlay) {
            overlay = document.createElement('div');
            overlay.className = 'singularity-overlay';
            document.body.appendChild(overlay);
          }
          
          overlay.style.setProperty('--x', `${x}px`);
          overlay.style.setProperty('--y', `${y}px`);
          
          // Force reflow
          void overlay.offsetWidth;
          
          document.body.classList.add('anim-singularity');
          
          setTimeout(() => {
            applyTheme(willBeDark);
            localStorage.setItem('theme', willBeDark ? 'dark' : 'light');
            // update the overlay color so it fades out correctly if needed
            overlay.style.background = getComputedStyle(document.documentElement).getPropertyValue('--bg-primary');
          }, 500); // Theme swap at full screen

          setTimeout(() => {
            document.body.classList.remove('anim-singularity');
            if(overlay) overlay.remove();
          }, 1000);
        }
      });
    });
  });
</script>
