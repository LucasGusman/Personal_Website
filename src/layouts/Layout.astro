---
import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Mascot from '../components/Mascot.jsx';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Personal portfolio exploring the digital cosmos." } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Google Fonts: Inter and Outfit -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@300;400;500;700&display=swap" rel="stylesheet">
		<ClientRouter />
	</head>
	<body class="min-h-screen flex flex-col relative overflow-x-hidden bg-[var(--bg-primary)] text-[var(--text-primary)] font-sans antialiased selection:bg-[var(--accent-teal)]/30 selection:text-[var(--text-primary)] pb-16 md:pb-0 md:pl-20 transition-colors duration-500">
		<!-- Background Elements -->
		<div class="fixed inset-0 z-[-2] bg-[var(--bg-primary)] pointer-events-none transition-colors duration-500"></div>
		<div class="fixed inset-0 z-[-1] bg-gradient-to-br from-[var(--bg-gradient-1)] via-[var(--bg-gradient-2)] to-[var(--bg-gradient-3)] opacity-80 pointer-events-none transition-colors duration-500"></div>
		
		<!-- Ambient Orbs (Subtle NASA Blue/Red glows) -->
		<div class="fixed top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-[var(--orb-teal)] blur-[120px] pointer-events-none z-[-1] transition-colors duration-500"></div>
		<div class="fixed bottom-[-10%] right-[-10%] w-[30%] h-[30%] rounded-full bg-[var(--orb-red)] blur-[100px] pointer-events-none z-[-1] transition-colors duration-500"></div>
		
		<Navigation />
		
		<main class="flex-grow flex flex-col relative z-10 antialiased">
			<slot />
		</main>
		
		<Footer />
		<Mascot client:only="react" transition:persist="mascot" />
	</body>
</html>
