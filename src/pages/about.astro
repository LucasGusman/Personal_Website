---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | Lucas">
  <div class="max-w-4xl mx-auto px-6 py-24 w-full">
    <div class="inline-block mb-12 transition-colors duration-500">
      <h1 class="text-4xl md:text-5xl font-baunk font-bold text-[var(--text-secondary)] mb-2 transition-colors duration-500">Origin Story</h1>
      <div class="h-1 w-1/3 bg-gradient-to-r from-[var(--accent-red)] to-transparent rounded-full transition-colors duration-500"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      <div class="md:col-span-8 prose max-w-none">
        <p class="text-lg text-[var(--text-primary)] font-medium leading-relaxed mb-6 transition-colors duration-500" data-mascot="I am currently reading your origin story. Fascinating timeline!">
          System operational. Awaiting command input.
        </p>
        <p class="text-lg text-[var(--text-primary)]/70 leading-relaxed transition-colors duration-500">
          This is where you can write your background, your mission, and the technologies you specialize in. The structure is set up to be sleek and legible, providing a refined reading experience.
        </p>
      </div>
      
      <div class="md:col-span-4">
        <div class="aspect-square bg-[var(--white-bg)] rounded-2xl border border-[var(--border-color)] shadow-sm flex items-center justify-center p-8 relative overflow-hidden group transition-colors duration-500">
          <div class="absolute inset-0 bg-gradient-to-tr from-[var(--accent-teal)]/5 to-[var(--accent-red)]/5 opacity-50 group-hover:opacity-100 transition-all duration-500"></div>
          <span class="text-[var(--text-primary)]/40 font-mono text-sm transition-colors duration-500">[Profile Image Payload]</span>
        </div>
      </div>
    </div>
  </div>
</Layout>
