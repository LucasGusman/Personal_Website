---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lucas | Explorer & Developer">
	<section class="min-h-[85vh] flex flex-col justify-center items-center text-center pt-20 px-6 max-w-6xl mx-auto w-full relative">
		<!-- Hero Content -->
		<div class="max-w-4xl z-10 w-full flex flex-col items-center">
			
			<p class="text-[var(--accent-red)] font-mono uppercase tracking-[0.3em] text-sm md:text-base mb-2 transition-colors duration-500">Welcome, I'm</p>
			<h1 class="text-[20vw] md:text-[14vw] leading-none font-baunk text-[var(--text-secondary)] mb-6 transition-colors duration-500 drop-shadow-2xl">
				LUCAS
			</h1>
			
			<p class="text-lg md:text-xl text-[var(--text-primary)]/80 font-light max-w-xl mx-auto mb-10 leading-relaxed transition-colors duration-500">
				Just a curious engineer who wants to understand how the world works...and build cool stuff...for space.
			</p>
			
			<div class="flex flex-wrap justify-center items-center gap-6">
				<a href="/projects" class="group relative px-8 py-4 bg-[var(--accent-red)] text-white font-semibold rounded-full hover:scale-105 transition-all shadow-[0_0_20px_var(--orb-red)] duration-500">
					<span class="relative z-10 flex items-center gap-2">
						Explore Projects
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 group-hover:translate-x-1 transition-transform">
							<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
						</svg>
					</span>
				</a>
				
				<a href="/about" class="px-8 py-4 text-[var(--text-primary)] font-medium rounded-full border border-[var(--border-hover)] bg-[var(--white-bg)] hover:bg-[var(--text-primary)]/5 transition-colors shadow-sm duration-500">
					Read Transmissions
				</a>
			</div>
		</div>

		<!-- Decorative Element -->
		<div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] md:w-[600px] h-[400px] md:h-[600px] rounded-full border border-[var(--border-color)] opacity-30 md:opacity-50 flex items-center justify-center animate-[spin_60s_linear_infinite] pointer-events-none transition-colors duration-500 z-[-1]">
			<div class="w-[250px] md:w-[400px] h-[250px] md:h-[400px] rounded-full border border-[var(--border-hover)] border-dashed absolute mix-blend-overlay transition-colors duration-500"></div>
			<div class="w-[150px] md:w-[200px] h-[150px] md:h-[200px] rounded-full bg-gradient-to-tr from-[var(--orb-teal)] to-[var(--orb-red)] blur-3xl opacity-50 transition-colors duration-500"></div>
			<div class="absolute top-0 left-1/2 w-4 h-4 rounded-full bg-[var(--accent-red)] shadow-[0_0_20px_var(--accent-red)] -translate-x-1/2 -translate-y-1/2 transition-colors duration-500"></div>
		</div>
	</section>

	<!-- Quick Features Section -->
	<section class="max-w-6xl mx-auto w-full px-6 py-12 relative z-10 border-t border-[var(--border-color)] bg-[var(--white-overlay)] transition-colors duration-500">
		<h2 class="text-3xl font-baunk font-medium mb-12 flex items-center gap-4 transition-colors duration-500">
			<span class="text-[var(--accent-red)]">01 //</span> Recent Logs
		</h2>
		
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			{[1, 2, 3].map((item) => (
				<div class="group p-8 rounded-2xl bg-[var(--white-bg)] border border-[var(--border-color)] hover:border-[var(--border-hover)] hover:shadow-lg transition-all duration-500 cursor-pointer relative overflow-hidden backdrop-blur-sm">
					<div class="text-[var(--text-primary)]/50 font-mono text-sm mb-4 border-b border-[var(--border-color)] pb-2 transition-colors duration-500">Log // 1969.{item}</div>
					<h3 class="text-xl font-medium text-[var(--text-primary)] mb-3 transition-colors duration-500">Voyager Probe {item}</h3>
					<p class="text-[var(--text-primary)]/70 text-sm leading-relaxed mb-6 transition-colors duration-500">
						A sleek and intriguing exploration into analog digital territories. High contrast red and blueprint teal applied cleanly.
					</p>
					<div class="text-[var(--accent-teal)] text-sm font-medium flex items-center gap-1 group-hover:gap-2 transition-all duration-500">
						Read File <span class="group-hover:translate-x-1 transition-transform">→</span>
					</div>
				</div>
			))}
		</div>
	</section>
</Layout>
