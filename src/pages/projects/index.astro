---
import Layout from '../../layouts/Layout.astro';
import ProjectsCarousel from '../../components/ProjectsCarousel.jsx';
---

<Layout title="Projects Catalog | Lucas">
  <!-- Wrapper for the whole page -->
  <div class="w-full min-h-screen flex flex-col pt-16 md:pt-32 relative">
    
    {/* Page Title - Standard Document Flow */}
    <div class="px-6 md:px-12 w-full max-w-7xl mx-auto z-20 mb-8 transition-colors duration-500">
      <h1 class="text-4xl md:text-6xl font-baunk font-bold text-[var(--text-secondary)] mb-2 transition-colors duration-500">Expedition Log</h1>
      <div class="h-1 w-24 bg-gradient-to-r from-[var(--accent-red)] to-transparent rounded-full mb-4 transition-colors duration-500"></div>
      <p class="text-[var(--text-primary)]/70 max-w-xs md:max-w-md text-sm md:text-base transition-colors duration-500">An interactive 3D archive of recent missions. Click and drag to spin the catalog.</p>
    </div>

    <!-- 3D Carousel Component Container -->
    <div class="flex-grow w-full relative">
      <ProjectsCarousel client:only="react" />
    </div>
  </div>
</Layout>
